<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main app theme -->
    <style name="Theme.TrustMeBro" parent="android:Theme.Black.NoTitleBar">
        <item name="android:statusBarColor">@color/tmb_background</item>
        <item name="android:navigationBarColor">@color/tmb_background</item>
        <item name="android:windowBackground">@color/tmb_background</item>
    </style>

    <!-- Splash screen theme — must use Theme.SplashScreen as parent -->
    <style name="Theme.TrustMeBro.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/tmb_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/tmb_background</item>
        <item name="postSplashScreenTheme">@style/Theme.TrustMeBro</item>
    </style>

</resources>
